# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Database (SQL Server example) ────────────────────────
# For SQL Server:  mssql+pyodbc://user:pass@server/dbname?driver=ODBC+Driver+17+for+SQL+Server
# For MySQL:       mysql+pymysql://user:pass@host/dbname
# For PostgreSQL:  postgresql://user:pass@host/dbname
# For SQLite:      sqlite:///data/raw/finance.db
DB_CONNECTION_STRING=sqlite:///data/raw/finance.db

# ── Email (Gmail App Password recommended) ───────────────
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_RECIPIENTS=cfo@company.com,finance@company.com,ops@company.com

# ── Report Settings ──────────────────────────────────────
REPORT_PERIOD=weekly          # weekly | monthly
COMPANY_NAME=Acme Corp
REPORT_OUTPUT_DIR=reports/output
